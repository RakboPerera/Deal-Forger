# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment variables — never commit API keys
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Database (auto-generated at runtime)
backend/data/dealforge.db
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3

# Uploaded documents (user data)
backend/storage/

# Build output
frontend/dist/
frontend/build/
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Temp
*.tmp
.cache/
.tmp/

# Package manager lockfiles from alternates
yarn.lock
pnpm-lock.yaml

# Test coverage
coverage/
.nyc_output/

# Runtime files
.claude/
